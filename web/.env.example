# Optional. Defaults to http://127.0.0.1:3000 when unset.
VITE_API_BASE_URL=http://127.0.0.1:3000

# Optional. Enables Clerk staff/admin sign-in UI when configured.
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_JWT_TEMPLATE=

# Optional. Match these to api/.env test participant values when testing live codes.
VITE_DEMO_PARTICIPANT_EMAIL=malia.demo@example.test
VITE_DEMO_PARTICIPANT_PHONE=671-555-0100
