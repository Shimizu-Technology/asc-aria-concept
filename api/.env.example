# Local prototype-only examples. Do not commit real secrets.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ASC_ARIA_ADMIN_API_TOKEN=replace-with-a-local-demo-token

# Anonymous public chat / secure handoff write throttles.
RACK_ATTACK_ENABLED=true
PUBLIC_CHAT_SESSION_RATE_LIMIT=20
PUBLIC_CHAT_MESSAGE_RATE_LIMIT=60
PUBLIC_CHAT_RATE_PERIOD_SECONDS=60
SECURE_HANDOFF_RATE_LIMIT=20
VERIFICATION_CHALLENGE_RATE_LIMIT=10
VERIFICATION_ATTEMPT_RATE_LIMIT=20
SECURE_HANDOFF_RATE_PERIOD_SECONDS=60

# Staff/admin auth (Clerk). Rails still owns app roles and permissions.
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_SECRET_KEY=
ASC_ARIA_STAFF_EMAIL=staff@example.test
ASC_ARIA_STAFF_NAME="ASC Staff Demo"

# Passwordless participant verification.
# Keep live sends disabled unless using allowlisted test contacts that you control.
ASC_ARIA_TEST_PARTICIPANT_EMAIL=malia.demo@example.test
ASC_ARIA_TEST_PARTICIPANT_PHONE=671-555-0100
RESEND_API_KEY=
MAILER_FROM_EMAIL=noreply@example.test
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_SENDER_ID=ASCTrust
LIVE_VERIFICATION_EMAILS_ENABLED=false
LIVE_VERIFICATION_SMS_ENABLED=false
LIVE_VERIFICATION_ALLOWLIST_REQUIRED=true
LIVE_VERIFICATION_ALLOWED_EMAILS=
LIVE_VERIFICATION_ALLOWED_PHONES=
DEMO_VERIFICATION_CODES_ENABLED=true
# Required in production. Use stable random values; rotating these invalidates stored contact/code digests.
CONTACT_DIGEST_SECRET=
VERIFICATION_CODE_SECRET=

# Optional. Public ARIA falls back to deterministic/template responses when unset.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_OPEN_TIMEOUT_SECONDS=15
OPENROUTER_READ_TIMEOUT_SECONDS=45
OPENROUTER_APP_NAME=ASC ARIA Prototype
OPENROUTER_SITE_URL=http://localhost:5173
